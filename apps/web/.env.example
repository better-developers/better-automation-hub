# Postgres connection string (Coolify VPS)
DATABASE_URL=postgresql://user:password@vps.yourdomain.com:5432/automation_hub

# BetterAuth — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL of this Next.js app (no trailing slash)
BETTER_AUTH_URL=https://your-app.yourdomain.com
NEXT_PUBLIC_AUTH_URL=https://your-app.yourdomain.com

# Optional: extra trusted origins for BetterAuth post-login redirects (comma-separated)
# Useful for Coolify preview deployments, e.g. https://preview.your-app.yourdomain.com
# BETTER_AUTH_TRUSTED_ORIGINS=

# Microsoft Entra ID (Azure AD) OAuth app
# Multi-tenant — any MS account can attempt login; access is gated by email allowlist
# Register at: https://portal.azure.com → App registrations
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
