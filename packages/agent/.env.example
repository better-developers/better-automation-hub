# Postgres connection string — same DB as the web app
DATABASE_URL=postgresql://user:password@vps.yourdomain.com:5432/automation_hub

# Anthropic API key for Claude calls
ANTHROPIC_API_KEY=sk-ant-

# UUID of the app user this agent runs for.
# Find it in the users table after the user has logged in via the web app at least once.
AGENT_USER_ID=

# Comma-separated list of integrations to activate: outlook, teams, github
ACTIVE_INTEGRATIONS=outlook,teams,github

# MS 365 MCP server URL (Outlook + Teams)
# Run locally: npx @softeria/ms-365-mcp-server --transport sse --port 3001
# Expose via Cloudflare tunnel and paste the public URL here
MS365_MCP_URL=https://your-tunnel.yourdomain.com/mcp

# GitHub fine-grained personal access token
# Scopes: Issues (read/write), Pull Requests (read/write), Metadata (read)
GITHUB_TOKEN=github_pat_

# GitHub MCP server URL (GitHub Copilot MCP or self-hosted)
GITHUB_MCP_URL=https://
